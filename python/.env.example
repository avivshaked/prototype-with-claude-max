# Copy this file to `.env` and paste your real OAuth token.
#   cp .env.example .env
#
# Generate a token by running `claude setup-token` in your terminal.
# It opens a browser flow and prints a 1-year, inference-scoped token
# that starts with `sk-ant-oat01-`. The token is tied to your Claude
# Pro/Max subscription — usage is billed against your subscription
# quota, not API credits.
#
# `.env` is gitignored. `.env.example` is not — it's the template
# new contributors copy from.

CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-paste-your-token-here
