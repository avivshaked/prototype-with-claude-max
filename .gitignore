# Secrets — never commit these. The repo provides .env.example
# files that you copy to .env and fill in locally.
.env
.env.local
.env.*.local
!.env.example

# Local Claude Code settings (per-user permissions etc.).
# .claude/settings.json IS meant to be committed — only the .local one isn't.
.claude/settings.local.json

# OS junk
.DS_Store
Thumbs.db

# IDE / editor
.idea/
.vscode/
*.swp
*.swo

# Python
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# Node / TypeScript
node_modules/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
